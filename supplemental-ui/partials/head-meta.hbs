{{!-- Injected into <head> AFTER the bundle's css/site.css, so the theme overlay
      wins the cascade. The inline script sets data-theme BEFORE first paint to
      avoid a flash of the wrong theme (FOUC). Badge and text-role styles that
      used to live here are now in css/theme.css so they adapt per theme. --}}
<link rel="stylesheet" href="{{uiRootPath}}/css/theme.css">
<script defer src="{{uiRootPath}}/js/code-toolbar.js"></script>
<script defer src="{{uiRootPath}}/js/ui-controls.js"></script>
<script>
  ;(function () {
    try {
      var KEY = 'adoc-ref-theme'
      var THEMES = { 'rose-dawn': 1, 'tokyo-night': 1, 'dracula': 1, 'nord': 1, 'gruvbox': 1 }
      var stored = localStorage.getItem(KEY)
      var theme = THEMES[stored]
        ? stored
        : (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'tokyo-night'
            : 'rose-dawn')
      document.documentElement.setAttribute('data-theme', theme)
      // Apply focus mode before paint too, so the sidebars don't flash in.
      if (localStorage.getItem('adoc-ref-focus') === '1') {
        document.documentElement.classList.add('is-focus')
      }
    } catch (e) {
      document.documentElement.setAttribute('data-theme', 'rose-dawn')
    }
  })()
</script>
