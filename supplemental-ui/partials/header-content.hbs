{{!-- Top navbar for the AsciiDoc + Antora Reference.
      Overrides the default UI's placeholder navigation (Home / Products / Services /
      Download, all dead "#" links) with the site title and links to the upstream
      AsciiDoc and Antora documentation. --}}
<header class="header">
  <nav class="navbar">
    <div class="navbar-brand">
      <a class="navbar-item" href="{{or site.url (or siteRootPath '/')}}">{{site.title}}</a>
      <button class="navbar-burger" aria-controls="topbar-nav" aria-expanded="false" aria-label="Toggle main menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
    <div id="topbar-nav" class="navbar-menu">
      <div class="navbar-end">
        <a class="navbar-item" href="https://docs.asciidoctor.org/asciidoc/latest/" target="_blank" rel="noopener">AsciiDoc docs</a>
        <a class="navbar-item" href="https://docs.antora.org" target="_blank" rel="noopener">Antora docs</a>
        <div class="navbar-item theme-switch">
          <label class="is-sr-only" for="theme-select">Color theme</label>
          <select id="theme-select" aria-label="Color theme" title="Color theme">
            <option value="rose-dawn">Rosé Pine Dawn</option>
            <option value="tokyo-night">Tokyo Night</option>
            <option value="dracula">Dracula</option>
            <option value="nord">Nord</option>
            <option value="gruvbox">Gruvbox</option>
          </select>
        </div>
      </div>
    </div>
  </nav>
</header>
<script>
  {{!-- Sync the picker with the theme already applied by head-meta.hbs, and
        persist the visitor's choice. The <select> exists above this script, so
        no DOMContentLoaded wait is needed. --}}
  ;(function () {
    var KEY = 'adoc-ref-theme'
    var sel = document.getElementById('theme-select')
    if (!sel) return
    var current = document.documentElement.getAttribute('data-theme') || 'rose-dawn'
    sel.value = current
    sel.addEventListener('change', function () {
      var value = sel.value
      document.documentElement.setAttribute('data-theme', value)
      try { localStorage.setItem(KEY, value) } catch (e) {}
    })
  })()
</script>
